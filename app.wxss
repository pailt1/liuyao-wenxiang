page {
  min-height: 100vh;
  background: #f7f1e8;
  color: #211814;
  font-family: -apple-system, BlinkMacSystemFont, "Helvetica Neue", Helvetica, Arial, sans-serif;
  font-size: 30rpx;
  line-height: 1.6;
}

view,
text,
button,
textarea {
  box-sizing: border-box;
}

.page {
  position: relative;
  min-height: 100vh;
  overflow: hidden;
  padding: 42rpx 40rpx 72rpx;
  background:
    radial-gradient(circle at 50% 16%, rgba(196, 154, 69, 0.12), transparent 30%),
    linear-gradient(180deg, #f7f1e8 0%, #f5efe3 100%);
}

.page::before {
  content: "";
  position: absolute;
  top: 220rpx;
  left: -140rpx;
  right: -140rpx;
  height: 320rpx;
  background:
    radial-gradient(ellipse at 15% 80%, rgba(74, 65, 55, 0.1) 0%, rgba(74, 65, 55, 0.06) 25%, transparent 54%),
    radial-gradient(ellipse at 85% 74%, rgba(74, 65, 55, 0.08) 0%, rgba(74, 65, 55, 0.04) 28%, transparent 58%);
  opacity: 0.72;
  pointer-events: none;
}

.page::after {
  content: "";
  position: absolute;
  left: -80rpx;
  right: -80rpx;
  bottom: -28rpx;
  height: 170rpx;
  background:
    radial-gradient(ellipse at 12% 100%, rgba(43, 33, 27, 0.16) 0%, rgba(43, 33, 27, 0.08) 30%, transparent 62%),
    radial-gradient(ellipse at 86% 100%, rgba(43, 33, 27, 0.14) 0%, rgba(43, 33, 27, 0.07) 32%, transparent 64%);
  opacity: 0.52;
  pointer-events: none;
}

.page-title {
  position: relative;
  z-index: 1;
  display: block;
  margin-bottom: 10rpx;
  font-size: 46rpx;
  font-weight: 700;
  color: #211814;
  letter-spacing: 0;
  text-align: center;
}

.page-subtitle {
  position: relative;
  z-index: 1;
  display: block;
  margin-bottom: 36rpx;
  color: #8a7c6a;
  font-size: 28rpx;
  text-align: center;
}

.section {
  position: relative;
  z-index: 1;
  margin-bottom: 32rpx;
  padding: 32rpx;
  border: 1rpx solid #e8ddcb;
  border-radius: 24rpx;
  background: rgba(255, 253, 248, 0.92);
  box-shadow: 0 12rpx 36rpx rgba(83, 65, 39, 0.08);
}

.section-title {
  display: block;
  margin-bottom: 16rpx;
  color: #211814;
  font-size: 32rpx;
  font-weight: 600;
}

.muted {
  display: block;
  color: #8a7c6a;
  font-size: 26rpx;
}

.primary-button {
  position: relative;
  z-index: 1;
  width: 100%;
  min-height: 92rpx;
  margin-top: 24rpx;
  border-radius: 28rpx;
  background: linear-gradient(135deg, #c49a45 0%, #a9781f 100%);
  color: #fffdf8;
  font-size: 34rpx;
  font-weight: 600;
  box-shadow: 0 14rpx 28rpx rgba(169, 120, 31, 0.2);
}

.primary-button[disabled] {
  background: rgba(169, 120, 31, 0.28);
  color: rgba(255, 253, 248, 0.86);
  box-shadow: none;
}

.secondary-button {
  position: relative;
  z-index: 1;
  width: 100%;
  min-height: 88rpx;
  margin-top: 20rpx;
  border: 1rpx solid #b8872b;
  border-radius: 28rpx;
  background: rgba(255, 253, 248, 0.72);
  color: #a9781f;
  font-size: 32rpx;
  font-weight: 600;
}

.ghost-button {
  min-height: 80rpx;
  border-color: #e8ddcb;
  color: #8a7c6a;
  font-size: 28rpx;
  font-weight: 500;
}

.disclaimer {
  position: relative;
  z-index: 1;
  margin-top: 36rpx;
  padding: 0 20rpx;
  color: #8a7c6a;
  font-size: 24rpx;
  text-align: center;
}

.tip-bar {
  position: relative;
  z-index: 1;
  display: flex;
  align-items: center;
  gap: 18rpx;
  margin: 28rpx 0;
  padding: 22rpx 26rpx;
  border: 1rpx solid #e8ddcb;
  border-radius: 24rpx;
  background: rgba(255, 253, 248, 0.78);
  color: #8a7c6a;
  font-size: 26rpx;
}

.tip-icon {
  display: flex;
  flex: 0 0 58rpx;
  align-items: center;
  justify-content: center;
  width: 58rpx;
  height: 58rpx;
  border: 1rpx solid rgba(184, 135, 43, 0.5);
  border-radius: 50%;
  color: #b8872b;
  font-size: 30rpx;
}

.line-symbol {
  display: flex;
  align-items: center;
}

.yang-symbol,
.empty-symbol {
  width: 100%;
  height: 14rpx;
  border-radius: 14rpx;
}

.yang-symbol {
  background: #211814;
}

.empty-symbol {
  border: 2rpx dashed rgba(33, 24, 20, 0.24);
}

.yin-symbol {
  display: flex;
  width: 100%;
  justify-content: space-between;
}

.yin-segment {
  height: 14rpx;
  border-radius: 14rpx;
  background: #211814;
}
