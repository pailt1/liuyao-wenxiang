.summary-card {
  display: flex;
  align-items: center;
  gap: 24rpx;
  margin-top: 34rpx;
}

.summary-icon {
  display: flex;
  flex: 0 0 82rpx;
  align-items: center;
  justify-content: center;
  width: 82rpx;
  height: 82rpx;
  border: 1rpx solid rgba(184, 135, 43, 0.55);
  border-radius: 50%;
  color: #a9781f;
  font-size: 34rpx;
}

.summary-content {
  flex: 1;
}

.question-text {
  display: block;
  margin-bottom: 12rpx;
  color: #211814;
  font-size: 34rpx;
  font-weight: 700;
  line-height: 1.45;
}

.error-box {
  position: relative;
  z-index: 1;
  margin-bottom: 28rpx;
  padding: 24rpx;
  border: 1rpx solid rgba(151, 67, 55, 0.24);
  border-radius: 20rpx;
  background: rgba(151, 67, 55, 0.08);
  color: #8f3d31;
  font-size: 26rpx;
}

.plate-card {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 28rpx;
  align-items: center;
}

.plate-lines {
  padding-right: 28rpx;
  border-right: 1rpx dashed rgba(184, 135, 43, 0.34);
}

.plate-line {
  display: grid;
  grid-template-columns: 72rpx 1fr 34rpx;
  align-items: center;
  min-height: 56rpx;
  color: #211814;
}

.plate-position {
  color: #211814;
  font-size: 26rpx;
}

.plate-line .line-symbol {
  width: 160rpx;
}

.plate-line .yang-symbol {
  width: 160rpx;
  height: 14rpx;
}

.plate-line .yin-symbol {
  width: 160rpx;
}

.plate-line .yin-segment {
  width: 68rpx;
  height: 14rpx;
}

.plate-line-moving .yang-symbol,
.plate-line-moving .yin-segment {
  background: #a33a2a;
}

.moving-dot {
  width: 22rpx;
  height: 22rpx;
  border: 4rpx solid #a33a2a;
  border-radius: 50%;
}

.plate-info-row {
  margin-bottom: 28rpx;
}

.plate-info-row:last-child {
  margin-bottom: 0;
}

.plate-label,
.plate-value,
.plate-meta {
  display: block;
}

.plate-label {
  color: #b8872b;
  font-size: 28rpx;
  font-weight: 600;
}

.plate-value {
  margin-top: 6rpx;
  color: #211814;
  font-size: 40rpx;
  font-weight: 800;
  line-height: 1.2;
}

.plate-meta {
  margin-top: 8rpx;
  color: #8a7c6a;
  font-size: 24rpx;
}

.moving-text {
  color: #a33a2a;
  font-size: 30rpx;
}

.conclusion-card {
  overflow: hidden;
}

.conclusion-card::after {
  content: "";
  position: absolute;
  right: 28rpx;
  bottom: 18rpx;
  width: 128rpx;
  height: 128rpx;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(184, 135, 43, 0.12), transparent 68%);
}

.ai-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 12rpx;
}

.ai-header .section-title {
  margin-bottom: 0;
  color: #b8872b;
}

.ai-source {
  color: #a9781f;
  font-size: 24rpx;
}

.ai-loading,
.ai-error {
  display: block;
  color: #8a7c6a;
  font-size: 26rpx;
}

.ai-error {
  margin-top: 20rpx;
  color: #8f3d31;
}

.conclusion-content {
  color: #2b211b;
  font-size: 30rpx;
  line-height: 1.8;
}

.analysis-list {
  position: relative;
  z-index: 1;
}

.ai-item {
  display: flex;
  gap: 22rpx;
  margin-bottom: 20rpx;
}

.analysis-icon {
  display: flex;
  flex: 0 0 62rpx;
  align-items: center;
  justify-content: center;
  width: 62rpx;
  height: 62rpx;
  border: 1rpx solid rgba(184, 135, 43, 0.5);
  border-radius: 50%;
  color: #b8872b;
  font-size: 26rpx;
  font-weight: 700;
}

.analysis-body {
  flex: 1;
}

.ai-title,
.ai-content {
  display: block;
}

.ai-title {
  margin-bottom: 8rpx;
  color: #211814;
  font-size: 30rpx;
  font-weight: 700;
}

.ai-content {
  color: #4a4036;
  font-size: 28rpx;
  line-height: 1.72;
  white-space: pre-wrap;
}

.action-row {
  position: relative;
  z-index: 1;
  display: grid;
  grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
  gap: 20rpx;
  width: 100%;
}

.action-button {
  width: auto;
  min-width: 0;
  max-width: 100%;
  padding-left: 0;
  padding-right: 0;
  margin-top: 0;
  margin-left: 0;
  margin-right: 0;
  font-size: 30rpx;
}

.save-status {
  position: relative;
  z-index: 1;
  margin: 24rpx 0;
  padding: 18rpx 22rpx;
  border-radius: 20rpx;
  color: #8a7c6a;
  font-size: 24rpx;
  text-align: center;
}

.save-status-saved {
  background: rgba(184, 135, 43, 0.1);
  color: #a9781f;
}

.save-status-saving {
  background: rgba(31, 29, 26, 0.06);
}

.save-status-failed {
  background: rgba(151, 67, 55, 0.08);
  color: #8f3d31;
}
