.state-box,
.error-box {
  position: relative;
  z-index: 1;
  margin-bottom: 28rpx;
  padding: 28rpx;
  border-radius: 24rpx;
  background: rgba(255, 253, 248, 0.9);
  color: #8a7c6a;
  font-size: 26rpx;
}

.error-box {
  border: 1rpx solid rgba(151, 67, 55, 0.24);
  background: rgba(151, 67, 55, 0.08);
  color: #8f3d31;
}

.summary-card {
  display: flex;
  align-items: center;
  gap: 24rpx;
  margin-top: 34rpx;
}

.summary-icon {
  display: flex;
  flex: 0 0 74rpx;
  align-items: center;
  justify-content: center;
  width: 74rpx;
  height: 74rpx;
  border: 1rpx solid rgba(184, 135, 43, 0.55);
  border-radius: 50%;
  color: #a9781f;
  font-size: 32rpx;
}

.summary-content {
  flex: 1;
}

.question-text {
  display: block;
  margin-bottom: 18rpx;
  color: #211814;
  font-size: 34rpx;
  font-weight: 700;
  line-height: 1.45;
}

.summary-meta-row {
  display: flex;
  flex-wrap: wrap;
  gap: 22rpx;
  color: #8a7c6a;
  font-size: 26rpx;
}

.compare-card {
  display: grid;
  grid-template-columns: 1fr 170rpx 1fr;
  gap: 18rpx;
  align-items: center;
  text-align: center;
}

.hex-label,
.hex-name,
.hex-meta,
.moving-mini {
  display: block;
}

.hex-label {
  color: #a9781f;
  font-size: 28rpx;
}

.hex-name {
  margin-top: 8rpx;
  color: #211814;
  font-size: 34rpx;
  font-weight: 800;
}

.hex-meta,
.moving-mini {
  margin-top: 6rpx;
  color: #8a7c6a;
  font-size: 24rpx;
}

.change-seal {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 150rpx;
  color: #a9781f;
  font-size: 58rpx;
  font-weight: 700;
}

.line-list {
  margin-top: 20rpx;
}

.line-item {
  display: grid;
  grid-template-columns: 88rpx 1fr 34rpx;
  align-items: center;
  min-height: 56rpx;
}

.line-position {
  color: #211814;
  font-size: 26rpx;
}

.line-symbol {
  width: 180rpx;
}

.line-item .yang-symbol {
  width: 180rpx;
  height: 14rpx;
}

.line-item .yin-symbol {
  width: 180rpx;
}

.line-item .yin-segment {
  width: 76rpx;
  height: 14rpx;
}

.line-moving .yang-symbol,
.line-moving .yin-segment {
  background: #a33a2a;
}

.moving-dot {
  width: 22rpx;
  height: 22rpx;
  border: 4rpx solid #a33a2a;
  border-radius: 50%;
}

.ai-section {
  margin-top: 32rpx;
}

.ai-item {
  display: flex;
  gap: 22rpx;
  padding: 22rpx 0;
  border-top: 1rpx solid rgba(123, 95, 47, 0.12);
}

.ai-item:first-of-type {
  border-top: 0;
}

.analysis-icon {
  display: flex;
  flex: 0 0 62rpx;
  align-items: center;
  justify-content: center;
  width: 62rpx;
  height: 62rpx;
  border: 1rpx solid rgba(184, 135, 43, 0.5);
  border-radius: 50%;
  color: #b8872b;
  font-size: 26rpx;
  font-weight: 700;
}

.analysis-body {
  flex: 1;
}

.ai-title,
.ai-content {
  display: block;
}

.ai-title {
  margin-bottom: 8rpx;
  color: #a9781f;
  font-size: 30rpx;
  font-weight: 700;
}

.ai-content {
  color: #4a4036;
  font-size: 28rpx;
  line-height: 1.72;
  white-space: pre-wrap;
}

.detail-actions {
  position: relative;
  z-index: 1;
  display: grid;
  grid-template-columns: 1fr 1fr 1fr;
  gap: 16rpx;
}

.action-button {
  min-height: 86rpx;
  margin-top: 0;
  font-size: 28rpx;
}

.delete-button {
  border-color: rgba(163, 58, 42, 0.4);
  color: #a33a2a;
}
